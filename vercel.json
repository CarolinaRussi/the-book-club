{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter frontend build",
  "outputDirectory": "frontend/dist",
  "crons": [
    {
      "path": "/api/ping",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
